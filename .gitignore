# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual Environment ---
# Exclude the massive 'venv' folder so you don't upload 100MB of library code
venv/
env/
.venv/

# --- Database ---
# NEVER commit your production database or local test DB
*.db
*.sqlite3
*.sqlite

# --- Environment Variables ---
# Crucial: Protects your API keys and secrets
.env
.env.local

# --- PyCharm / IDE Settings ---
# Exclude user-specific editor settings
.idea/
.vscode/
*.swp

# --- OS Generated Files ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log